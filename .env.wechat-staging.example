# Dedicated environment for the WeChat experience build.
# Install as /etc/hina/wechat-staging.env with mode 600.
APP_ENV="staging"
NODE_ENV="production"
APP_URL="https://wx-dev.hina-cn.cn"
PORT="3010"
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Use a dedicated database so experience users cannot touch production data.
DATABASE_URL="postgres://hina_wechat_staging:replace-me@127.0.0.1:5432/hina_wechat_staging"
REDIS_URL="redis://:replace-me@127.0.0.1:6379"
REDIS_KEY_PREFIX="hina:wechat-staging"

ARK_API_KEY=""
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_CHAT_MODEL=""
ARK_TTS_ENDPOINT=""

SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Hina <hina-cn@foxmail.com>"

WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_MINI_APP_ID=""
WECHAT_MINI_APP_SECRET=""
WECHAT_MINI_DEV_LOGIN="false"
WECHAT_CONTENT_SECURITY_ENABLED="true"

CHAT_RATE_LIMIT_PER_MINUTE="30"
TTS_RATE_LIMIT_PER_MINUTE="10"
