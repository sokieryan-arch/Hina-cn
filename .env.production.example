# Production profile.
# Use this only behind a real HTTPS domain. For bare public-IP HTTP testing,
# keep using `.env` with NODE_ENV="development" so browser cookies keep working.

APP_URL="https://hina.example.cn"
PORT="3000"
NODE_ENV="production"
SESSION_SECRET="replace-with-at-least-32-random-characters"

DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
REDIS_URL="redis://:PASSWORD@HOST:6379"

ARK_API_KEY="replace-with-volcengine-ark-api-key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_CHAT_MODEL="replace-with-model-or-endpoint-id"
ARK_TTS_ENDPOINT=""

FREE_DAILY_CHAT_LIMIT="30"
PRO_DAILY_CHAT_LIMIT="0"

# SMS is intentionally not wired in the current production baseline.
# Phone verification returns phone_verification_unavailable until real SMS is implemented.
VOLCENGINE_SMS_ACCESS_KEY_ID=""
VOLCENGINE_SMS_SECRET_ACCESS_KEY=""
VOLCENGINE_SMS_SIGN_NAME=""
VOLCENGINE_SMS_TEMPLATE_ID=""

# Required in production for real email verification codes.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Hina <no-reply@hina.example.cn>"

WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
