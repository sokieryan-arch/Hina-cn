# Staging profile for public-IP HTTP testing.
# This keeps NODE_ENV=development so browser cookies work over plain HTTP,
# but APP_ENV=staging disables development fallbacks such as local dev codes.

APP_URL="http://PUBLIC_IP:3000"
PORT="3000"
APP_ENV="staging"
NODE_ENV="development"
SESSION_SECRET="replace-with-at-least-32-random-characters"

DATABASE_URL="postgres://hina_app:PASSWORD@127.0.0.1:5432/hina_cn"
REDIS_URL="redis://:PASSWORD@127.0.0.1:6379"
REDIS_KEY_PREFIX="hina:staging"

ARK_API_KEY="replace-with-volcengine-ark-api-key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_CHAT_MODEL="replace-with-model-or-endpoint-id"
ARK_TTS_ENDPOINT=""

FREE_DAILY_CHAT_LIMIT="30"
PRO_DAILY_CHAT_LIMIT="0"

VOLCENGINE_SMS_ACCESS_KEY_ID=""
VOLCENGINE_SMS_SECRET_ACCESS_KEY=""
VOLCENGINE_SMS_SIGN_NAME=""
VOLCENGINE_SMS_TEMPLATE_ID=""

SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_USER="hina-cn@foxmail.com"
SMTP_PASS="replace-with-smtp-authorization-code"
SMTP_FROM="Hina <hina-cn@foxmail.com>"

WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# Mini Program credentials stay on the server. Never put the secret in the
# miniprogram source tree or project configuration.
WECHAT_MINI_APP_ID=""
WECHAT_MINI_APP_SECRET=""
WECHAT_MINI_DEV_LOGIN="false"
WECHAT_CONTENT_SECURITY_ENABLED="false"
